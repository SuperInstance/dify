# SuperInstance Model Roster Configuration
# Copy this file to superinstance-models.env (without .example) to activate.

# ── Primary Provider: z.ai ──────────────────────────────
SIA_ZAI_API_KEY=your-zai-api-key-here
SIA_ZAI_BASE_URL=https://api.zai.chat/v1
SIA_ZAI_DEFAULT_MODEL=glm-5.1

# Available z.ai models:
# - glm-5.1         (primary — best quality, all tasks)
# - glm-4-flash     (fast responses, simple tasks)

# ── Fallback Provider: DeepInfra ────────────────────────
SIA_DEEPINFRA_API_KEY=your-deepinfra-api-key-here
SIA_DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# Model roster (comma-separated, tried in order):
SIA_DEEPINFRA_ROSTER=deepinfra/seed-2.0-mini,deepinfra/gemma-4,deepinfra/nemotron-120b,deepinfra/qwen-3.6,deepinfra/hermes-405b

# DeepInfra model descriptions:
# - seed-2.0-mini    Fastest, cheapest — simple classification/extraction
# - gemma-4          Balanced — general chat, summarization
# - nemotron-120b    High reasoning — complex analysis, code review
# - qwen-3.6         Versatile — multilingual, instruction following
# - hermes-405b      Maximum capability — long context, creative writing

# ── Fallback Strategy ───────────────────────────────────
# "ordered" tries models in roster order; "random" distributes load; "cost" picks cheapest
SIA_FALLBACK_STRATEGY=ordered

# Max retries before giving up (across all fallback models)
SIA_FALLBACK_MAX_RETRIES=5

# ── Budget (integrates with Budget Watchdog) ─────────────
# Monthly spend limit in USD (0 = unlimited)
SIA_MONTHLY_BUDGET_LIMIT=0

# Per-request cost limit in USD (0 = unlimited)
SIA_PER_REQUEST_COST_LIMIT=0

# Warning threshold (percentage of budget, 0-100)
SIA_BUDGET_WARNING_THRESHOLD=80
